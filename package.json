{
    "name": "antigravity-telegram-control",
    "displayName": "Antigravity Telegram Control",
    "description": "Control Antigravity Agent via Telegram and take screenshots.",
    "version": "0.0.7",
    "publisher": "acmatvjrus",
    "repository": {
        "type": "git",
        "url": "https://github.com/acmavirus/antigravity-telegram-control.git"
    },
    "homepage": "https://github.com/acmavirus/antigravity-telegram-control",
    "icon": "resources/logo.png",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "antigravity-telegram-control.startBot",
                "title": "Telegram: Start Bot"
            },
            {
                "command": "antigravity-telegram-control.stopBot",
                "title": "Telegram: Stop Bot"
            },
            {
                "command": "antigravity-telegram-control.openSettings",
                "title": "Telegram: Open Custom Settings"
            },
            {
                "command": "antigravity-telegram-control.registerCommands",
                "title": "Telegram: Register Slash Commands"
            },
            {
                "command": "antigravity-telegram-control.deleteCommands",
                "title": "Telegram: Delete Slash Commands"
            },
            {
                "command": "antigravity-telegram-control.refreshQuota",
                "title": "Telegram: Refresh Quota Status"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "telegram-control",
                    "title": "Telegram Control",
                    "icon": "resources/activity-bar.svg"
                }
            ]
        },
        "views": {
            "telegram-control": [
                {
                    "id": "telegram-control-welcome",
                    "name": "Telegram Settings",
                    "type": "webview",
                    "icon": "$(settings-gear)"
                }
            ]
        },
        "configuration": {
            "title": "Antigravity Telegram Control",
            "properties": {
                "antigravityTelegramControl.botToken": {
                    "type": "string",
                    "default": "",
                    "description": "Your Telegram Bot Token from @BotFather"
                },
                "antigravityTelegramControl.allowedChatId": {
                    "type": "string",
                    "default": "",
                    "description": "Allowed Telegram Chat ID to control the agent"
                },
                "antigravityTelegramControl.debuggingPort": {
                    "type": "number",
                    "default": 9222,
                    "description": "VS Code / Antigravity IDE remote debugging port (launch IDE with --remote-debugging-port=9222)"
                },
                "antigravityTelegramControl.language": {
                    "type": "string",
                    "default": "en",
                    "description": "Language for Telegram bot messages"
                },
                "antigravityTelegramControl.agentsMsPath": {
                    "type": "string",
                    "default": "",
                    "description": "Full path to your agents.md file"
                },
                "antigravityTelegramControl.geminiMdPath": {
                    "type": "string",
                    "default": "",
                    "description": "Full path to your gemini.md file"
                },
                "antigravityTelegramControl.autoRetry": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically retry if the agent fails or times out"
                },
                "antigravityTelegramControl.showStatusBar": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show the Antigravity quota and credits in the VS Code status bar (bottom bar)"
                },
                "antigravityTelegramControl.statusBarUpdateInterval": {
                    "type": "number",
                    "default": 60,
                    "description": "Interval in seconds to update the status bar"
                },
                "antigravityTelegramControl.autoAccept": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically accept Antigravity Agent steps and terminal commands locally (independent of Telegram)"
                },
                "antigravityTelegramControl.autoAcceptInterval": {
                    "type": "number",
                    "default": 800,
                    "description": "Interval in milliseconds to check and auto-accept agent actions (minimum: 200ms)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/node": "16.x",
        "@types/vscode": "^1.75.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^5.53.0",
        "@typescript-eslint/parser": "^5.53.0",
        "@vscode/vsce": "^2.15.0",
        "eslint": "^8.34.0",
        "typescript": "^4.9.5"
    },
    "dependencies": {
        "screenshot-desktop": "^1.12.7",
        "telegraf": "^4.12.2",
        "ws": "^8.19.0"
    },
    "overrides": {
        "undici": "5.28.4"
    }
}